{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "co_worker",
  "version": "0.1.0",
  "identifier": "dev.co-worker.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm --workspace co_worker_desktop run dev",
    "beforeBuildCommand": "npm --workspace co_worker_desktop run build"
  },
  "app": {
    "windows": [
      {
        "title": "co_worker",
        "width": 1100,
        "height": 720,
        "minWidth": 720,
        "minHeight": 480,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
